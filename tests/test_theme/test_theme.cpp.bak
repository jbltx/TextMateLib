// ============================================================================
// Multiple Theme Tests
// ============================================================================

TEST_F(ThemeTest, LoadMultipleThemes_SwitchBetween) {
    TextMateTheme theme1 = textmate_theme_load_from_file("test-cases/themes/dark_plus.json");
    TextMateTheme theme2 = textmate_theme_load_from_file("test-cases/themes/light_plus.json");

    ASSERT_NE(theme1, nullptr);
    ASSERT_NE(theme2, nullptr);

    // Get colors from both themes
    uint32_t darkFg = textmate_theme_get_default_foreground(theme1);
    uint32_t lightFg = textmate_theme_get_default_foreground(theme2);

    // Foreground colors should be different
    EXPECT_NE(darkFg, lightFg);

    textmate_theme_dispose(theme1);
    textmate_theme_dispose(theme2);
}

// ============================================================================
// Theme Consistency Tests
// ============================================================================

TEST_F(ThemeTest, LoadSameThemeTwice_ConsistentResults) {
    TextMateTheme theme1 = textmate_theme_load_from_file("test-cases/themes/dark_plus.json");
    TextMateTheme theme2 = textmate_theme_load_from_file("test-cases/themes/dark_plus.json");

    ASSERT_NE(theme1, nullptr);
    ASSERT_NE(theme2, nullptr);

    // Both themes should return same colors for same scope
    uint32_t color1 = textmate_theme_get_foreground(theme1, "comment", 0);
    uint32_t color2 = textmate_theme_get_foreground(theme2, "comment", 0);

    EXPECT_EQ(color1, color2);

    textmate_theme_dispose(theme1);
    textmate_theme_dispose(theme2);
}

TEST_F(ThemeTest, ColorFormat_Consistency) {
    // Test that color format is consistent (0xRRGGBBAA)
    const char* jsonTheme = R"({
        "name": "Color Test",
        "settings": [
            {
                "scope": "test.red",
                "settings": {
                    "foreground": "#FF0000"
                }
            },
            {
                "scope": "test.green",
                "settings": {
                    "foreground": "#00FF00"
                }
            },
            {
                "scope": "test.blue",
                "settings": {
                    "foreground": "#0000FF"
                }
            }
        ]
    })";

    TextMateTheme theme = textmate_theme_load_from_json(jsonTheme);
    ASSERT_NE(theme, nullptr);

    // Get colors - they should be in format 0xRRGGBBAA
    uint32_t red = textmate_theme_get_foreground(theme, "test.red", 0);
    uint32_t green = textmate_theme_get_foreground(theme, "test.green", 0);
    uint32_t blue = textmate_theme_get_foreground(theme, "test.blue", 0);

    // Colors should be non-zero (and different from each other)
    EXPECT_NE(red, 0);
    EXPECT_NE(green, 0);
    EXPECT_NE(blue, 0);
    EXPECT_NE(red, green);
    EXPECT_NE(green, blue);

    textmate_theme_dispose(theme);
}

// ============================================================================
// Memory Cleanup Tests
// ============================================================================

TEST_F(ThemeTest, DisposeTheme_NoLeaksOnMultipleCalls) {
    TextMateTheme theme = textmate_theme_load_from_file("test-cases/themes/dark_plus.json");
    ASSERT_NE(theme, nullptr);

    // Dispose once
    textmate_theme_dispose(theme);

    // Note: In real scenarios, calling dispose twice on the same pointer
    // would be undefined behavior, so we don't test that.
    // Instead, we verify that a newly loaded theme works after disposal

    TextMateTheme theme2 = textmate_theme_load_from_file("test-cases/themes/dark_plus.json");
    ASSERT_NE(theme2, nullptr);

    textmate_theme_dispose(theme2);
}

// ============================================================================
// JSON Theme Variations Tests
// ============================================================================

TEST_F(ThemeTest, LoadTheme_SingleStringScope) {
    const char* jsonTheme = R"({
        "name": "Single Scope Test",
        "settings": [
            {
                "scope": "comment",
                "settings": {
                    "foreground": "#888888"
                }
            }
        ]
    })";

    TextMateTheme theme = textmate_theme_load_from_json(jsonTheme);
    ASSERT_NE(theme, nullptr);

    uint32_t color = textmate_theme_get_foreground(theme, "comment", 0);
    EXPECT_NE(color, 0);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, LoadTheme_ArrayOfScopes) {
    const char* jsonTheme = R"({
        "name": "Array Scope Test",
        "settings": [
            {
                "scope": ["comment", "punctuation.definition.comment"],
                "settings": {
                    "foreground": "#888888"
                }
            }
        ]
    })";

    TextMateTheme theme = textmate_theme_load_from_json(jsonTheme);
    ASSERT_NE(theme, nullptr);

    uint32_t color1 = textmate_theme_get_foreground(theme, "comment", 0);
    uint32_t color2 = textmate_theme_get_foreground(theme, "punctuation.definition.comment", 0);

    EXPECT_NE(color1, 0);
    EXPECT_NE(color2, 0);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, LoadTheme_NoScopeDefaultSettings) {
    const char* jsonTheme = R"({
        "name": "Default Settings Test",
        "settings": [
            {
                "settings": {
                    "foreground": "#FFFFFF",
                    "background": "#000000"
                }
            }
        ]
    })";

    TextMateTheme theme = textmate_theme_load_from_json(jsonTheme);
    ASSERT_NE(theme, nullptr);

    uint32_t defaultFg = textmate_theme_get_default_foreground(theme);
    uint32_t defaultBg = textmate_theme_get_default_background(theme);

    EXPECT_NE(defaultFg, 0);
    EXPECT_NE(defaultBg, 0);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, LoadTheme_WithFontStyles) {
    const char* jsonTheme = R"({
        "name": "Font Style Test",
        "settings": [
            {
                "scope": "italic.test",
                "settings": {
                    "fontStyle": "italic"
                }
            },
            {
                "scope": "bold.test",
                "settings": {
                    "fontStyle": "bold"
                }
            },
            {
                "scope": "underline.test",
                "settings": {
                    "fontStyle": "underline"
                }
            },
            {
                "scope": "combined.test",
                "settings": {
                    "fontStyle": "bold italic underline"
                }
            }
        ]
    })";

    TextMateTheme theme = textmate_theme_load_from_json(jsonTheme);
    ASSERT_NE(theme, nullptr);

    int32_t italicStyle = textmate_theme_get_font_style(theme, "italic.test", 0);
    int32_t boldStyle = textmate_theme_get_font_style(theme, "bold.test", 0);
    int32_t underlineStyle = textmate_theme_get_font_style(theme, "underline.test", 0);
    int32_t combinedStyle = textmate_theme_get_font_style(theme, "combined.test", 0);

    // Verify font styles are recognized
    EXPECT_GT(italicStyle, 0);
    EXPECT_GT(boldStyle, 0);
    EXPECT_GT(underlineStyle, 0);
    EXPECT_GT(combinedStyle, 0);

    textmate_theme_dispose(theme);
}

// ============================================================================
// Edge Cases and Robustness Tests
// ============================================================================

TEST_F(ThemeTest, LoadTheme_EmptySettings) {
    const char* jsonTheme = R"({
        "name": "Empty Settings",
        "settings": []
    })";

    TextMateTheme theme = textmate_theme_load_from_json(jsonTheme);
    ASSERT_NE(theme, nullptr);

    // Should still work, just return defaults
    uint32_t fg = textmate_theme_get_default_foreground(theme);
    EXPECT_NE(fg, 0);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, LoadTheme_MissingName) {
    const char* jsonTheme = R"({
        "settings": [
            {
                "scope": "comment",
                "settings": {
                    "foreground": "#888888"
                }
            }
        ]
    })";

    TextMateTheme theme = textmate_theme_load_from_json(jsonTheme);
    ASSERT_NE(theme, nullptr);

    uint32_t color = textmate_theme_get_foreground(theme, "comment", 0);
    EXPECT_NE(color, 0);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, GetColor_EmptyScopePath) {
    TextMateTheme theme = textmate_theme_load_from_file("test-cases/themes/dark_plus.json");
    ASSERT_NE(theme, nullptr);

    uint32_t defaultColor = 0xFFFFFFFF;
    uint32_t color = textmate_theme_get_foreground(theme, "", defaultColor);

    // Empty scope path should return default
    EXPECT_EQ(color, defaultColor);

    textmate_theme_dispose(theme);
}
