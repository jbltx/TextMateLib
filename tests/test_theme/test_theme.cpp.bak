}

TEST_F(ThemeTest, GetFontStyle_NullTheme) {
    int32_t defaultStyle = TEXTMATE_FONT_STYLE_BOLD;
    int32_t style = textmate_theme_get_font_style(nullptr, "comment", defaultStyle);
    EXPECT_EQ(style, defaultStyle);
