{
  "name": "textmatelib-monorepo",
  "version": "1.0.0",
  "description": "TextMateLib - High-performance syntax highlighting with TextMate grammars",
  "private": true,
  "homepage": "https://github.com/jbltx/TextMateLib",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbltx/TextMateLib.git"
  },
  "license": "MIT",
  "author": "TextMateLib Contributors",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky install",
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=packages/textmatelib",
    "test": "npm run test --workspaces",
    "test:run": "npm run test:run --workspaces",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "lint-staged": {
    "packages/**/*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
