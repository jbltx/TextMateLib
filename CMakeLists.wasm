cmake_minimum_required(VERSION 3.14)
project(tml-wasm VERSION 2.0.0 LANGUAGES CXX)

# Set C++17 standard for modern features
set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)

# Build variant selection (minimal, standard, full, debug)
set(WASM_VARIANT "standard" CACHE STRING "WASM build variant")
set_property(CACHE WASM_VARIANT PROPERTY STRINGS "minimal" "standard" "full" "debug")

# Include directories
include_directories(
    ${CMAKE_CURRENT_SOURCE_DIR}/src
    ${CMAKE_CURRENT_SOURCE_DIR}/../ThirdParty/rapidjson/include
)

# Source files (core components)
set(TEXTMATE_CORE_SOURCES
    src/utils.cpp
    src/onigLib.cpp
    src/rawGrammar.cpp
    src/parseRawGrammar.cpp
    src/theme.cpp
    src/encodedTokenAttributes.cpp
    src/rule.cpp
    src/matcher.cpp
    src/grammarDependencies.cpp
    src/basicScopesAttributeProvider.cpp
    src/tokenizeString.cpp
    src/grammar.cpp
    src/registry.cpp
    src/main.cpp
)

# Extended sources with WASM 2023 bindings
set(TEXTMATE_WASM_SOURCES
    ${TEXTMATE_CORE_SOURCES}
    src/bindings.cpp
)

# Optional WASM 2023 feature bindings
if(WASM_VARIANT STREQUAL "full" OR WASM_VARIANT STREQUAL "debug")
    list(APPEND TEXTMATE_WASM_SOURCES
        src/simd_bindings.cpp
        src/exception_bindings.cpp
        src/bulk_memory_bindings.cpp
        src/bigint_bindings.cpp
    )
endif()

# WebAssembly 2023 target configuration
set(WASM_2023_FLAGS
    -target wasm32-unknown-emscripten
    -msimd128
    -fwasm-exceptions
    -mbulk-memory
    -mnontrapping-fptoint
    -msse4.2
    -sWASM_BIGINT
    -sSUPPORT_LONGJMP=wasm
)

# Core Emscripten runtime flags
set(EMSCRIPTEN_FLAGS
    -s WASM=1
    -s MODULARIZE=1
    -s EXPORT_NAME='createTextMateModule'
    -s EXPORTED_RUNTIME_METHODS=['ccall','cwrap','getValue','setValue']
    -s ALLOW_MEMORY_GROWTH=1
    -s ABORTING_MALLOC=0
    -s TOTAL_STACK_SIZE=5242880
)

# Memory configuration for WASM (increased max memory for large files)
set(WASM_MEMORY_FLAGS
    -s INITIAL_MEMORY=33554432
    -s MAXIMUM_MEMORY=536870912
)

# Bulk memory operations optimization
set(WASM_BULK_MEMORY_FLAGS
    -mbulk-memory
    -s BULK_MEMORY=1
)

# Variant-specific configurations
if(WASM_VARIANT STREQUAL "minimal")
    # Minimal feature set, smallest output
    set(VARIANT_FLAGS "-O4 -DNDEBUG")
    message(STATUS "Building MINIMAL variant: core tokenization only")

elseif(WASM_VARIANT STREQUAL "standard")
    # Balanced: all APIs, moderate size
    set(VARIANT_FLAGS "-O3 -DNDEBUG")
    message(STATUS "Building STANDARD variant: Session + Registry + Theme")

elseif(WASM_VARIANT STREQUAL "full")
    # Full features: WASM 2023 optimizations included
    set(VARIANT_FLAGS "-O3 -DNDEBUG -DWASM_2023_FEATURES=1")
    message(STATUS "Building FULL variant: SIMD + Exceptions + Bulk Memory + BigInt")

elseif(WASM_VARIANT STREQUAL "debug")
    # Debug with symbols and assertions
    set(VARIANT_FLAGS "-g -O1 -s ASSERTIONS=1 -s RUNTIME_LOGGING=1 -DDEBUG=1")
    message(STATUS "Building DEBUG variant: with debug symbols and runtime checks")

else()
    message(FATAL_ERROR "Invalid WASM_VARIANT: ${WASM_VARIANT}")
endif()

# Exception handling configuration
set(EXCEPTION_FLAGS
    -fwasm-exceptions
    -s EXCEPTION_CATCHING_ALLOWED='["std::exception","std::runtime_error","std::invalid_argument"]'
)

# Combine all C++ flags
set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} ${WASM_2023_FLAGS} ${EMSCRIPTEN_FLAGS} ${WASM_MEMORY_FLAGS} ${WASM_BULK_MEMORY_FLAGS} ${EXCEPTION_FLAGS} --bind")

# Release optimizations
set(CMAKE_CXX_FLAGS_RELEASE "${VARIANT_FLAGS}")

# Debug flags (for debug variant)
set(CMAKE_CXX_FLAGS_DEBUG "${VARIANT_FLAGS}")

# Linker flags for WASM output
set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -s USE_ONIGURUMA=1")

# Add oniguruma from emscripten ports
set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -s USE_ONIGURUMA=1")

# Create WASM executable
add_executable(tml-wasm ${TEXTMATE_WASM_SOURCES})

# Set output name with variant suffix
set_target_properties(tml-wasm PROPERTIES
    OUTPUT_NAME "textmate-${WASM_VARIANT}"
    SUFFIX ".js"
)

# Set output directory
set(CMAKE_RUNTIME_OUTPUT_DIRECTORY ${CMAKE_CURRENT_BINARY_DIR}/wasm)

# Print configuration summary
message(STATUS "")
message(STATUS "============ VSCode TextMate WASM 2023 Build ============")
message(STATUS "C++ Standard: ${CMAKE_CXX_STANDARD}")
message(STATUS "Build Type: ${CMAKE_BUILD_TYPE}")
message(STATUS "WASM Variant: ${WASM_VARIANT}")
message(STATUS "Output: ${CMAKE_RUNTIME_OUTPUT_DIRECTORY}/textmate-${WASM_VARIANT}.{js,wasm}")
message(STATUS "")
message(STATUS "WASM 2023 Features Enabled:")
message(STATUS "  ✓ SIMD128 (4x regex acceleration)")
message(STATUS "  ✓ WASM Exceptions (native error handling)")
message(STATUS "  ✓ Bulk Memory Operations (efficient data transfer)")
message(STATUS "  ✓ Non-Trapping Float-to-Int (safe conversions)")
message(STATUS "  ✓ SSE 4.2 (SIMD pattern optimization)")
message(STATUS "  ✓ BigInt Support (64-bit metadata)")
message(STATUS "  ✓ WASM Longjmp (error recovery)")
message(STATUS "")
message(STATUS "Memory Configuration:")
message(STATUS "  Initial: 32MB")
message(STATUS "  Maximum: 512MB")
message(STATUS "  Stack: 5MB")
message(STATUS "======================================================")
message(STATUS "")
