}

TEST_F(ThemeTest, GetFontStyle_UnknownScope_ReturnDefault) {
    const char* themePath = "test-cases/themes/dark_plus.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_NE(theme, nullptr);

    int32_t defaultStyle = TEXTMATE_FONT_STYLE_ITALIC;
    int32_t style = textmate_theme_get_font_style(
        theme,
        "unknown.scope.xyz",
        defaultStyle
    );

    EXPECT_EQ(style, defaultStyle);

