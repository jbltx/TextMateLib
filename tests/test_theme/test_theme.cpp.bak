TEST_F(ThemeTest, GetForegroundColor_NestedScope_DarkPlus) {
    const char* themePath = "test-cases/themes/dark_plus.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_NE(theme, nullptr);

    // Test nested scope path
    uint32_t color = textmate_theme_get_foreground(
        theme,
        "source.csharp keyword.control",
        0x00000000
    );

    // Should get some color
    EXPECT_NE(color, 0x00000000);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, GetForegroundColor_UnknownScope_ReturnDefault) {
    const char* themePath = "test-cases/themes/dark_plus.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_NE(theme, nullptr);

    uint32_t defaultColor = 0xFFFF00FF;  // Magenta
    uint32_t color = textmate_theme_get_foreground(
        theme,
        "unknown.scope.that.does.not.exist",
        defaultColor
    );

    // Should return the default color
    EXPECT_EQ(color, defaultColor);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, GetForegroundColor_NullTheme) {
    uint32_t defaultColor = 0xFFFF0000;
    uint32_t color = textmate_theme_get_foreground(nullptr, "comment", defaultColor);
    EXPECT_EQ(color, defaultColor);
}

TEST_F(ThemeTest, GetForegroundColor_NullScopePath) {
    const char* themePath = "test-cases/themes/dark_plus.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_NE(theme, nullptr);

    uint32_t defaultColor = 0xFFFF0000;
    uint32_t color = textmate_theme_get_foreground(theme, nullptr, defaultColor);
    EXPECT_EQ(color, defaultColor);

    textmate_theme_dispose(theme);
