{
  "name": "textmatelib",
  "version": "1.0.0",
  "description": "High-performance syntax highlighting engine with TextMate grammar support and WebAssembly bindings",
  "homepage": "https://github.com/jbltx/TextMateLib",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbltx/TextMateLib.git"
  },
  "license": "MIT",
  "author": "TextMateLib Contributors",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./low-level": {
      "import": "./dist/low-level.mjs",
      "require": "./dist/low-level.cjs",
      "types": "./dist/low-level.d.ts"
    },
    "./high-level": {
      "import": "./dist/high-level.mjs",
      "require": "./dist/high-level.cjs",
      "types": "./dist/high-level.d.ts"
    }
  },
  "files": [
    "dist",
    "wasm",
    "scripts",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest",
    "test:run": "vitest run",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "syntax",
    "highlighting",
    "grammar",
    "textmate",
    "wasm",
    "tokenization"
  ],
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/ui": "^1.1.0",
    "terser": "^5.44.1",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-dts": "^1.7.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
