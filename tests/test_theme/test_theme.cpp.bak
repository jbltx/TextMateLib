// ============================================================================
// Default Color Tests
// ============================================================================

TEST_F(ThemeTest, GetDefaultForeground_DarkPlus) {
    const char* themePath = "test-cases/themes/dark_plus.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_NE(theme, nullptr);

    uint32_t fgColor = textmate_theme_get_default_foreground(theme);
    // Dark+ default foreground should be a light color
    EXPECT_NE(fgColor, 0);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, GetDefaultBackground_DarkPlus) {
    const char* themePath = "test-cases/themes/dark_plus.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_NE(theme, nullptr);

    uint32_t bgColor = textmate_theme_get_default_background(theme);
    // Dark+ default background should be a dark color
    EXPECT_NE(bgColor, 0);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, GetDefaultForeground_NullTheme) {
    uint32_t fgColor = textmate_theme_get_default_foreground(nullptr);
    // Should return white as fallback
    EXPECT_EQ(fgColor, 0xFFFFFFFF);
}

TEST_F(ThemeTest, GetDefaultBackground_NullTheme) {
    uint32_t bgColor = textmate_theme_get_default_background(nullptr);
    // Should return black as fallback
    EXPECT_EQ(bgColor, 0x000000FF);
}

// ============================================================================
// Scope Color Tests
// ============================================================================

TEST_F(ThemeTest, GetForegroundColor_Comment_DarkPlus) {
    const char* themePath = "test-cases/themes/dark_plus.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_NE(theme, nullptr);

    // Comment scope should have a specific color in dark_plus
    uint32_t commentColor = textmate_theme_get_foreground(
        theme,
        "comment",
        0x00000000
    );

    // Should return a color (not default)
    // Comments are typically gray/dark in dark_plus
    EXPECT_NE(commentColor, 0x00000000);

    textmate_theme_dispose(theme);
}

TEST_F(ThemeTest, GetForegroundColor_Keyword_DarkPlus) {
    const char* themePath = "test-cases/themes/dark_plus.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_NE(theme, nullptr);

    // Keyword scope
    uint32_t keywordColor = textmate_theme_get_foreground(
        theme,
        "keyword",
        0x00000000
    );

    EXPECT_NE(keywordColor, 0x00000000);

    textmate_theme_dispose(theme);
}

