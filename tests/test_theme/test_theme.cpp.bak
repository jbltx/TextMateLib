TEST_F(ThemeTest, DISABLED_LoadThemeFromFile_NonExistent) {
    const char* themePath = "test-cases/themes/nonexistent.json";
    TextMateTheme theme = textmate_theme_load_from_file(themePath);
    ASSERT_EQ(theme, nullptr);
